<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ShelterManager.Models"
             x:Class="ShelterManager.InventoryPage"
             Title="Magazyn"
             BackgroundColor="#F2F5F8">

    <Grid RowDefinitions="Auto, *">
        
        <VerticalStackLayout Grid.Row="0" Margin="0,20,0,20" Spacing="5">
            <Label Text="MAGAZYN" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#333333" 
                   HorizontalOptions="Center"
                   CharacterSpacing="2"/>
            
            <Label Text="Zarządzanie zapasami i karmą" 
                   FontSize="14" 
                   TextColor="#999999" 
                   HorizontalOptions="Center"/>
            
            <BoxView HeightRequest="4" 
                     WidthRequest="60" 
                     Color="#FF9800" 
                     CornerRadius="2" 
                     HorizontalOptions="Center"
                     Margin="0,5,0,0"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" 
                        x:Name="ListaZasobow"
                        ItemsSource="{Binding Zasoby}"
                        Margin="15">
            
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" 
                                 Span="2" 
                                 HorizontalItemSpacing="15" 
                                 VerticalItemSpacing="15"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Zasob">
                    
                    <Frame Padding="0" 
                           CornerRadius="20" 
                           HasShadow="True" 
                           BorderColor="Transparent" 
                           BackgroundColor="White"
                           HeightRequest="190">

                        <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="10">
                            
                            <Label Grid.Row="0" 
                                   Text="{Binding Nazwa}" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="#444444" 
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation"/>

                            <Grid Grid.Row="1" ColumnDefinitions="40, *, 40" VerticalOptions="Center">
                                <Button Grid.Column="0"
                                        Text="-"
                                        Clicked="OnMinusClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#F0F0F0"
                                        TextColor="Black"
                                        FontAttributes="Bold"
                                        FontSize="20"
                                        Padding="0"
                                        CornerRadius="10"
                                        HeightRequest="40"
                                        WidthRequest="40"/>

                                <Label Grid.Column="1" 
                                       Text="{Binding Ilosc}" 
                                       FontSize="36" 
                                       FontAttributes="Bold" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"
                                       TextColor="#2196F3"> <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Ilosc}" Value="0">
                                            <Setter Property="TextColor" Value="#F44336"/> </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <Button Grid.Column="2"
                                        Text="+"
                                        Clicked="OnPlusClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#E3F2FD"
                                        TextColor="#2196F3"
                                        FontAttributes="Bold"
                                        FontSize="20"
                                        Padding="0"
                                        CornerRadius="10"
                                        HeightRequest="40"
                                        WidthRequest="40"/>
                            </Grid>

                            <Label Grid.Row="2" 
                                   Text="sztuk" 
                                   FontSize="11" 
                                   TextColor="#999999" 
                                   HorizontalOptions="Center"
                                   Margin="0,0,0,5"/>

                            <Button Grid.Row="3"
                                    Text="Usuń"
                                    Clicked="OnDeleteClicked"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#FFEBEE"
                                    TextColor="#D32F2F"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    HeightRequest="30"
                                    Padding="0"
                                    CornerRadius="15"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <Button Grid.Row="1"
                Text="+" 
                Clicked="OnAddTypeClicked"
                FontSize="32"
                TextColor="White"
                BackgroundColor="#FF9800" 
                CornerRadius="35"
                WidthRequest="70"
                HeightRequest="70"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="25"
                Shadow="{Shadow Brush=Black, Offset='2,2', Opacity=0.3, Radius=5}"/>
    </Grid>
</ContentPage>