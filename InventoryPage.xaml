<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ShelterManager.Models"
             x:Class="ShelterManager.InventoryPage"
             Title="Magazyn"
             BackgroundColor="#F4F7FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <LinearGradientBrush x:Key="FabGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2196F3" Offset="0.0" />
                <GradientStop Color="#21CBF3" Offset="1.0" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid MaximumWidthRequest="1000" HorizontalOptions="Center" RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Margin="{OnIdiom Phone='0,16,0,12', Tablet='0,30,0,25', Desktop='0,30,0,25'}" Spacing="8">
            <Label Text="MAGAZYN" 
                   FontSize="{OnIdiom Phone=24, Tablet=32, Desktop=32}" 
                   FontAttributes="Bold" 
                   TextColor="#1A237E" 
                   HorizontalOptions="Center" 
                   CharacterSpacing="1"/>

            <Label Text="Zarządzanie zapasami i karmą" 
                   FontSize="{OnIdiom Phone=13, Tablet=16, Desktop=16}" 
                   TextColor="#7986CB" 
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" 
                        x:Name="ListaZasobow"
                        ItemsSource="{Binding Zasoby}" 
                        Margin="{OnIdiom Phone='12,0,12,12', Tablet='20,0,20,20', Desktop='20,0,20,20'}">

            <CollectionView.ItemsLayout>
                <GridItemsLayout x:Name="InventoryGridLayout"
                                 Orientation="Vertical" 
                                 Span="2" 
                                 HorizontalItemSpacing="20" 
                                 VerticalItemSpacing="20"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Zasob">
                    <Border StrokeShape="RoundRectangle 25" 
                            BackgroundColor="White" 
                            StrokeThickness="0"
                            MinimumHeightRequest="{OnIdiom Phone=190, Tablet=200, Desktop=200}">

                        <Border.Shadow>
                            <Shadow Brush="#546E7A" Offset="0,5" Opacity="0.15" Radius="15"/>
                        </Border.Shadow>

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" Padding="15" RowSpacing="10">

                            <!-- Nagłówek karty: ikona + nazwa + status + akcje
                                 Uwaga: rozbijamy na osobne kolumny (Auto,*,Auto,Auto,Auto), aby długie nazwy
                                 nie "wchodziły" pod badge i przyciski. IsClippedToBounds wymusza poprawne obcięcie. -->
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                                  ColumnSpacing="10"
                                  IsClippedToBounds="True">

                                <Border Grid.Column="0" StrokeShape="RoundRectangle 12" BackgroundColor="#E3F2FD" StrokeThickness="0" Padding="8" VerticalOptions="Center">
                                    <Label Text="📦" FontSize="18"/>
                                </Border>

                                <Label Grid.Column="1"
                                       Text="{Binding Nazwa}"
                                       FontSize="{OnIdiom Phone=14, Tablet=15, Desktop=15}"
                                       FontAttributes="Bold"
                                       TextColor="#37474F"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Center"/>

                                <Border Grid.Column="2"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        Padding="8,4"
                                        BackgroundColor="#E8F5E9"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding Status}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextTransform="Uppercase"
                                           TextColor="#2E7D32">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Ilosc}" Value="0">
                                                <Setter Property="TextColor" Value="#C62828"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsLowStock}" Value="True">
                                                <Setter Property="TextColor" Value="#EF6C00"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding Ilosc}" Value="0">
                                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsLowStock}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#FFF3E0"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>

                                <Button Grid.Column="3"
                                        Text="⚙"
                                        Clicked="OnEditThresholdClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="#78909C"
                                        FontSize="18"
                                        HeightRequest="30"
                                        WidthRequest="30"
                                        Padding="0"
                                        HorizontalOptions="End"
                                        VerticalOptions="Center"/>

                                <Button Grid.Column="4"
                                        Text="✕"
                                        Clicked="OnDeleteClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="#EF5350"
                                        FontSize="18"
                                        HeightRequest="30"
                                        WidthRequest="30"
                                        Padding="0"
                                        HorizontalOptions="End"
                                        VerticalOptions="Center"/>

                            </Grid>

                            <!-- Ilość + jednostka -->
                            <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="6">
                                <Label Text="{Binding Ilosc, StringFormat='{0:0.##}'}" 
                                       FontSize="{OnIdiom Phone=30, Tablet=40, Desktop=40}" 
                                       FontAttributes="Bold" 
                                       TextColor="#1565C0"
                                       VerticalOptions="End">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Ilosc}" Value="0">
                                            <Setter Property="TextColor" Value="#EF5350"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsLowStock}" Value="True">
                                            <Setter Property="TextColor" Value="#F57C00"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <Label Grid.Column="1"
                                       Text="{Binding Jednostka}"
                                       FontSize="12"
                                       TextColor="#78909C"
                                       VerticalOptions="End"
                                       Margin="0,0,0,6"/>
                            </Grid>

                            <!-- Próg niskiego stanu -->
                            <Label Grid.Row="2" FontSize="11" TextColor="#90A4AE">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Próg: " />
                                        <Span Text="{Binding LowStockThreshold, StringFormat='{0:0.##}'}" />
                                        <Span Text=" " />
                                        <Span Text="{Binding Jednostka}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <!-- Akcje ilości -->
                            <Grid Grid.Row="3" ColumnDefinitions="45,*,45" ColumnSpacing="10">
                                <Button Grid.Column="0" 
                                        Text="-" 
                                        Clicked="OnMinusClicked" 
                                        CommandParameter="{Binding .}" 
                                        BackgroundColor="#F5F5F5" 
                                        TextColor="#546E7A" 
                                        CornerRadius="12" 
                                        Padding="0" 
                                        HeightRequest="{OnIdiom Phone=36, Tablet=40, Desktop=40}" 
                                        FontAttributes="Bold" 
                                        FontSize="18"/>

                                <Label Grid.Column="1" 
                                       Text="{Binding Jednostka}" 
                                       FontSize="12" 
                                       TextColor="#B0BEC5" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center" 
                                       TextTransform="Uppercase"/>

                                <Button Grid.Column="2" 
                                        Text="+" 
                                        Clicked="OnPlusClicked" 
                                        CommandParameter="{Binding .}" 
                                        BackgroundColor="#E3F2FD" 
                                        TextColor="#1565C0" 
                                        CornerRadius="12" 
                                        Padding="0" 
                                        HeightRequest="{OnIdiom Phone=36, Tablet=40, Desktop=40}" 
                                        FontAttributes="Bold" 
                                        FontSize="18"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1"
                Text="+" 
                Clicked="OnAddTypeClicked"
                FontSize="{OnIdiom Phone=32, Tablet=36, Desktop=36}"
                TextColor="White"
                Background="{StaticResource FabGradient}"
                CornerRadius="35"
                WidthRequest="{OnIdiom Phone=60, Tablet=70, Desktop=70}"
                HeightRequest="{OnIdiom Phone=60, Tablet=70, Desktop=70}"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="{OnIdiom Phone=16, Tablet=30, Desktop=30}"
                Shadow="{Shadow Brush=#2196F3, Offset='0,8', Opacity=0.4, Radius=15}"/>
    </Grid>
</ContentPage>