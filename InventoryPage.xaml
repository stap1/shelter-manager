<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ShelterManager.Models"
             x:Class="ShelterManager.InventoryPage"
             Title="Magazyn"
             BackgroundColor="#F4F7FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <LinearGradientBrush x:Key="FabGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2196F3" Offset="0.0" />
                <GradientStop Color="#21CBF3" Offset="1.0" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid MaximumWidthRequest="1000" HorizontalOptions="Center" RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Margin="0,30,0,25" Spacing="8">
            <Label Text="MAGAZYN" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="#1A237E" 
                   HorizontalOptions="Center" 
                   CharacterSpacing="1"/>

            <Label Text="Zarządzanie zapasami i karmą" 
                   FontSize="16" 
                   TextColor="#7986CB" 
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" 
                        x:Name="ListaZasobow"
                        ItemsSource="{Binding Zasoby}" 
                        Margin="20,0,20,20">

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="20" VerticalItemSpacing="20"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Zasob">
                    <Border StrokeShape="RoundRectangle 25" 
                            BackgroundColor="White" 
                            StrokeThickness="0" 
                            HeightRequest="160">

                        <Border.Shadow>
                            <Shadow Brush="#546E7A" Offset="0,5" Opacity="0.15" Radius="15"/>
                        </Border.Shadow>

                        <Grid RowDefinitions="Auto, *, Auto" Padding="15">

                            <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto">
                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                    <Border StrokeShape="RoundRectangle 12" BackgroundColor="#E3F2FD" StrokeThickness="0" Padding="8">
                                        <Label Text="📦" FontSize="18"/>
                                    </Border>
                                    <Label Text="{Binding Nazwa}" 
                                           FontSize="15" 
                                           FontAttributes="Bold" 
                                           TextColor="#37474F" 
                                           LineBreakMode="TailTruncation"
                                           VerticalOptions="Center"
                                           MaxLines="2"/>
                                </HorizontalStackLayout>

                                <Button Grid.Column="1"
                                        Text="⚙"
                                        Clicked="OnEditThresholdClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="#78909C"
                                        FontSize="18"
                                        HeightRequest="30"
                                        WidthRequest="30"
                                        Padding="0"
                                        HorizontalOptions="End"
                                        VerticalOptions="Start"/>

                                <Button Grid.Column="2"
                                        Text="✕"
                                        Clicked="OnDeleteClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="#EF5350"
                                        FontSize="18"
                                        HeightRequest="30"
                                        WidthRequest="30"
                                        Padding="0"
                                        HorizontalOptions="End"
                                        VerticalOptions="Start"/>
                            </Grid>

                            <Label Grid.Row="1" 
                                   Text="{Binding Ilosc}" 
                                   FontSize="40" 
                                   FontAttributes="Bold" 
                                   TextColor="#1565C0" 
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Ilosc}" Value="0">
                                        <Setter Property="TextColor" Value="#EF5350"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Grid Grid.Row="2" ColumnDefinitions="45, *, 45">
                                <Button Grid.Column="0" 
                                        Text="-" 
                                        Clicked="OnMinusClicked" 
                                        CommandParameter="{Binding .}" 
                                        BackgroundColor="#F5F5F5" 
                                        TextColor="#546E7A" 
                                        CornerRadius="12" 
                                        Padding="0" 
                                        HeightRequest="40" 
                                        FontAttributes="Bold" 
                                        FontSize="18"/>

                                <Label Grid.Column="1" 
                                       Text="szt." 
                                       FontSize="12" 
                                       TextColor="#B0BEC5" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center" 
                                       TextTransform="Uppercase"/>

                                <Button Grid.Column="2" 
                                        Text="+" 
                                        Clicked="OnPlusClicked" 
                                        CommandParameter="{Binding .}" 
                                        BackgroundColor="#E3F2FD" 
                                        TextColor="#1565C0" 
                                        CornerRadius="12" 
                                        Padding="0" 
                                        HeightRequest="40" 
                                        FontAttributes="Bold" 
                                        FontSize="18"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1"
                Text="+" 
                Clicked="OnAddTypeClicked"
                FontSize="36"
                TextColor="White"
                Background="{StaticResource FabGradient}"
                CornerRadius="35"
                WidthRequest="70"
                HeightRequest="70"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="30"
                Shadow="{Shadow Brush=#2196F3, Offset='0,8', Opacity=0.4, Radius=15}"/>
    </Grid>
</ContentPage>