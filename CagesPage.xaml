<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ShelterManager.Models"
             x:Class="ShelterManager.CagesPage"
             Title="Klatki"
             BackgroundColor="#F4F7FA">

    <Grid MaximumWidthRequest="1000" HorizontalOptions="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <VerticalStackLayout Grid.Row="0" Margin="0,30,0,25" Spacing="8">
            <Label Text="KLATKI I BOKSY" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="#1A237E" 
                   HorizontalOptions="Center"
                   CharacterSpacing="1"/>

            <Label Text="Podgląd na żywo mieszkańców" 
                   FontSize="16" 
                   TextColor="#7986CB" 
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Klatki}"
                        Margin="20,0,20,20">

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" 
                                 Span="2" 
                                 HorizontalItemSpacing="20" 
                                 VerticalItemSpacing="20"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Klatka">
                    <Grid>

                        <Border StrokeShape="RoundRectangle 20"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                HeightRequest="140">

                            <Border.Shadow>
                                <Shadow Brush="#546E7A" Offset="0,5" Opacity="0.15" Radius="10"/>
                            </Border.Shadow>

                            <Grid ColumnDefinitions="120, *">
                                <Grid Grid.Column="0">
                                    <BoxView Color="#F5F5F5"/>
                                    <ActivityIndicator IsRunning="True" Color="#2196F3" Scale="0.5"/>
                                    <Image Source="{Binding Lokator.Zdjecie}"
                                           Aspect="AspectFill"
                                           HorizontalOptions="Fill"
                                           VerticalOptions="Fill"/>
                                </Grid>

                                <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="15,12">
                                    <Border Grid.Row="0" HorizontalOptions="Start" BackgroundColor="#E3F2FD" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="8,4">
                                        <Label Text="{Binding Numer, StringFormat='BOKS {0}'}" FontSize="10" TextColor="#1565C0" FontAttributes="Bold"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Lokator.Imie}" FontSize="18" FontAttributes="Bold" TextColor="#263238" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Lokator.Rasa}" FontSize="12" TextColor="#78909C" LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>

                                    <Label Grid.Row="2" Text="🔴 ZAJĘTA" FontSize="10" TextColor="#D32F2F" FontAttributes="Bold" HorizontalOptions="End"/>
                                </Grid>
                            </Grid>

                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CzyZajeta}" Value="False">
                                    <Setter Property="IsVisible" Value="False"/>
                                </DataTrigger>
                            </Border.Triggers>
                        </Border>


                        <Border StrokeShape="RoundRectangle 20"
                                BackgroundColor="#F1F8E9"
                                Stroke="#81C784"
                                StrokeThickness="1"
                                HeightRequest="140"
                                IsVisible="False">

                            <Grid RowDefinitions="*, Auto, Auto" Padding="15">
                                <Label Grid.Row="0" Text="🏠" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.8"/>

                                <Label Grid.Row="1" 
                                       Text="WOLNE" 
                                       TextColor="#2E7D32" 
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       HorizontalOptions="Center" 
                                       CharacterSpacing="1"/>

                                <Label Grid.Row="2" Text="{Binding Numer, StringFormat='Boks nr {0}'}" TextColor="#66BB6A" FontSize="12" HorizontalOptions="Center" Margin="0,5,0,0"/>
                            </Grid>

                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CzyZajeta}" Value="False">
                                    <Setter Property="IsVisible" Value="True"/>
                                </DataTrigger>
                            </Border.Triggers>
                        </Border>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>