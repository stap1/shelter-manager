<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ShelterManager.Models"
             x:Class="ShelterManager.CagesPage"
             Title="Klatki"
             BackgroundColor="#F4F7FA">

    <Grid MaximumWidthRequest="1000" HorizontalOptions="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <VerticalStackLayout Grid.Row="0" Margin="{OnIdiom Phone='0,16,0,12', Tablet='0,30,0,25', Desktop='0,30,0,25'}" Spacing="8">
            <Label Text="KLATKI I BOKSY" 
                   FontSize="{OnIdiom Phone=24, Tablet=32, Desktop=32}" 
                   FontAttributes="Bold" 
                   TextColor="#1A237E" 
                   HorizontalOptions="Center"
                   CharacterSpacing="1"/>

            <Label Text="Podgląd na żywo mieszkańców" 
                   FontSize="{OnIdiom Phone=13, Tablet=16, Desktop=16}" 
                   TextColor="#7986CB" 
                   HorizontalOptions="Center"/>

            <!-- Ponieważ Shell.NavBarIsVisible="False", dodajemy przycisk w treści strony -->
            <Button Text="ZARZĄDZAJ BOKSAMI"
                    Clicked="OnManageCagesClicked"
                    HorizontalOptions="Center"
                    BackgroundColor="#1A237E"
                    TextColor="White"
                    CornerRadius="12"
                    Padding="16,10" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" 
                        x:Name="CagesCollection"
                        ItemsSource="{Binding Klatki}"
                        Margin="{OnIdiom Phone='12,0,12,12', Tablet='20,0,20,20', Desktop='20,0,20,20'}">

            <CollectionView.ItemsLayout>
                <GridItemsLayout x:Name="CagesGridLayout"
                                 Orientation="Vertical" 
                                 Span="2" 
                                 HorizontalItemSpacing="20" 
                                 VerticalItemSpacing="20"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Cage">
                    <Grid>

                        <Border StrokeShape="RoundRectangle 20"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                HeightRequest="{OnIdiom Phone=120, Tablet=140, Desktop=140}">

                            <Border.Shadow>
                                <Shadow Brush="#546E7A" Offset="0,5" Opacity="0.15" Radius="10"/>
                            </Border.Shadow>

                            <Grid ColumnDefinitions="120, *">
                                <Grid Grid.Column="0">
                                    <BoxView Color="#F5F5F5"/>
                                    <ActivityIndicator IsRunning="True" Color="#2196F3" Scale="0.5"/>
                                    <Image Source="{Binding PrimaryAnimal.Zdjecie}"
                                           Aspect="AspectFill"
                                           HorizontalOptions="Fill"
                                           VerticalOptions="Fill"/>
                                </Grid>

                                <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="15,12">
                                    <Border Grid.Row="0" HorizontalOptions="Start" BackgroundColor="#E3F2FD" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="8,4">
                                        <Label Text="{Binding Numer, StringFormat='BOKS {0}'}" FontSize="10" TextColor="#1565C0" FontAttributes="Bold"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding PrimaryAnimal.Imie}" FontSize="18" FontAttributes="Bold" TextColor="#263238" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding PrimaryAnimal.Rasa}" FontSize="12" TextColor="#78909C" LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>

                                    <Label Grid.Row="2" Text="{Binding OccupancyText, StringFormat='🔴 ZAJĘTE {0}'}" FontSize="10" TextColor="#D32F2F" FontAttributes="Bold" HorizontalOptions="End"/>
                                </Grid>
                            </Grid>

                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="IsVisible" Value="False"/>
                                </DataTrigger>
                            </Border.Triggers>
                        </Border>


                        <Border StrokeShape="RoundRectangle 20"
                                BackgroundColor="#F1F8E9"
                                Stroke="#81C784"
                                StrokeThickness="1"
                                HeightRequest="{OnIdiom Phone=120, Tablet=140, Desktop=140}"
                                IsVisible="False">

						<Grid RowDefinitions="*, Auto, Auto, Auto" Padding="15">
                                <Label Grid.Row="0" Text="🏠" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.8"/>

                                <Label Grid.Row="1" 
                                       Text="WOLNE" 
                                       TextColor="#2E7D32" 
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       HorizontalOptions="Center" 
                                       CharacterSpacing="1"/>


							<Label Grid.Row="2"
							       Text="{Binding OccupancyText, StringFormat='Obłożenie: {0}'}"
							       TextColor="#66BB6A"
							       FontSize="12"
							       HorizontalOptions="Center"
							       Margin="0,5,0,0"/>

							<Label Grid.Row="3" Text="{Binding Numer, StringFormat='Boks nr {0}'}" TextColor="#66BB6A" FontSize="12" HorizontalOptions="Center" Margin="0,2,0,0"/>
                            </Grid>

                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="IsVisible" Value="True"/>
                                </DataTrigger>
                            </Border.Triggers>
                        </Border>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>