<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShelterManager.AdoptionApplicationDetailsPage"
             Title="Szczegóły wniosku"
             BackgroundColor="#F4F7FA">

    <Grid MaximumWidthRequest="900" HorizontalOptions="Center" RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Margin="0,30,0,20" Spacing="6">
            <Label Text="SZCZEGÓŁY WNIOSKU"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1A237E"
                   HorizontalOptions="Center"
                   CharacterSpacing="1"/>

            <Label Text="Zarządzanie statusem i notatkami"
                   FontSize="14"
                   TextColor="#7986CB"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1" Margin="20,0,20,20">
            <VerticalStackLayout Spacing="14">

                <Border StrokeShape="RoundRectangle 20" BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.Shadow>
                        <Shadow Brush="#90A4AE" Offset="0,4" Opacity="0.12" Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Dane wniosku" FontAttributes="Bold" TextColor="#37474F" FontSize="16"/>

                        <Label Text="{Binding ApplicantName, StringFormat='Wnioskodawca: {0}'}" TextColor="#607D8B"/>
                        <Label Text="{Binding Contact, StringFormat='Kontakt: {0}'}" TextColor="#607D8B"/>
                        <Label Text="{Binding AnimalOpis, StringFormat='Zwierzę: {0}'}" TextColor="#607D8B"/>

                        <Border BackgroundColor="#E3F2FD" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="10,4" HorizontalOptions="Start">
                            <Label Text="{Binding StatusOpis}" FontAttributes="Bold" TextColor="#1565C0" FontSize="12"/>
                        </Border>

                        <Label Text="Notatki" FontAttributes="Bold" TextColor="#37474F" FontSize="14"/>
                        <Editor x:Name="NotesEditor"
                                Text="{Binding Notes}"
                                AutoSize="TextChanges"
                                Placeholder="Dodaj notatki (np. wynik rozmowy, uwagi)..."
                                BackgroundColor="#F5F7FA"
                                TextColor="#37474F"/>

                        <Button Text="ZAPISZ NOTATKI"
                                Clicked="OnSaveNotesClicked"
                                CornerRadius="16"
                                FontAttributes="Bold"
                                BackgroundColor="#2196F3"
                                TextColor="White"/>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 20" BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.Shadow>
                        <Shadow Brush="#90A4AE" Offset="0,4" Opacity="0.12" Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Workflow" FontAttributes="Bold" TextColor="#37474F" FontSize="16"/>

                        <Label Text="Nowy → W weryfikacji → Zatwierdzony / Odrzucony" TextColor="#607D8B"/>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <Button x:Name="BtnInReview"
                                    Grid.Column="0"
                                    Text="WERYFIKUJ"
                                    Clicked="OnInReviewClicked"
                                    CornerRadius="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="#FF9800"
                                    TextColor="White"/>

                            <Button x:Name="BtnApprove"
                                    Grid.Column="1"
                                    Text="ZATWIERDŹ"
                                    Clicked="OnApproveClicked"
                                    CornerRadius="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="#4CAF50"
                                    TextColor="White"/>

                            <Button x:Name="BtnReject"
                                    Grid.Column="2"
                                    Text="ODRZUĆ"
                                    Clicked="OnRejectClicked"
                                    CornerRadius="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="#F44336"
                                    TextColor="White"/>
                        </Grid>

                        <Button Text="WRÓĆ"
                                Clicked="OnBackClicked"
                                CornerRadius="16"
                                FontAttributes="Bold"
                                BackgroundColor="#E3F2FD"
                                TextColor="#1A237E"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
