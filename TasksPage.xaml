<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ShelterManager.Models"
             x:Class="ShelterManager.TasksPage"
             Title="Zadania"
             BackgroundColor="#F4F7FA">

    <Grid MaximumWidthRequest="900" HorizontalOptions="Center" RowDefinitions="Auto, Auto, *">

        <!-- Nagłówek -->
        <VerticalStackLayout Grid.Row="0" Margin="0,30,0,20" Spacing="6">
            <Label Text="HARMONOGRAM OPIEKI"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1A237E"
                   HorizontalOptions="Center"
                   CharacterSpacing="1"/>

            <Label Text="Dzisiaj i nadchodzące zadania"
                   FontSize="14"
                   TextColor="#7986CB"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Sterowanie: widok + filtry + dodawanie -->
        <Border Grid.Row="1"
                Margin="20,0,20,20"
                StrokeShape="RoundRectangle 20"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="14">

            <Border.Shadow>
                <Shadow Brush="#90A4AE" Offset="0,4" Opacity="0.15" Radius="10"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *, *, Auto" RowSpacing="10" ColumnSpacing="10">

                <Button x:Name="BtnToday"
                        Grid.Row="0" Grid.Column="0"
                        Text="DZIŚ"
                        Clicked="OnTodayClicked"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        BackgroundColor="#2196F3"
                        TextColor="White"/>

                <Button x:Name="BtnUpcoming"
                        Grid.Row="0" Grid.Column="1"
                        Text="NADCHODZĄCE"
                        Clicked="OnUpcomingClicked"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        BackgroundColor="#E3F2FD"
                        TextColor="#1A237E"/>

                <Label Grid.Row="0" Grid.Column="2"
                       Text="Filtry:"
                       VerticalTextAlignment="Center"
                       TextColor="#607D8B"
                       FontAttributes="Bold"/>

                <Button Grid.Row="0" Grid.Column="3"
                        Text="+ DODAJ"
                        Clicked="OnAddTaskClicked"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        BackgroundColor="#4CAF50"
                        TextColor="White"/>

                <Picker x:Name="PickerStatus"
                        Grid.Row="1" Grid.Column="0"
                        Title="Status"
                        SelectedIndexChanged="OnFilterChanged"/>

                <Picker x:Name="PickerType"
                        Grid.Row="1" Grid.Column="1"
                        Title="Typ"
                        SelectedIndexChanged="OnFilterChanged"/>

                <Picker x:Name="PickerAnimal"
                        Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                        Title="Zwierzę"
                        SelectedIndexChanged="OnFilterChanged"/>
            </Grid>
        </Border>

        <!-- Lista -->
        <!--
            Uwaga: na Windows (WinUI) CollectionView potrafi w określonych układach powodować
            System.AccessViolationException podczas nawigacji do strony.
            Aby ustabilizować aplikację, wyświetlamy zadania przez BindableLayout (bez wirtualizacji).
        -->
        <ScrollView Grid.Row="2" Margin="20,0">
            <VerticalStackLayout Spacing="12"
                                 BindableLayout.ItemsSource="{Binding WidoczneZadania}">

                <VerticalStackLayout.BindableLayout.EmptyView>
                    <Label Text="Brak zadań dla wybranych kryteriów."
                           TextColor="#90A4AE"
                           HorizontalOptions="Center"
                           Margin="0,20,0,0"/>
                </VerticalStackLayout.BindableLayout.EmptyView>

                <VerticalStackLayout.BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:Zadanie">
                        <Border StrokeShape="RoundRectangle 18"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                Padding="0">

                            <Grid ColumnDefinitions="54, *, Auto, Auto" Padding="0,14">

                                <!-- Zamiast CheckBox: przycisk przełączający stan (stabilniejsze na WinUI) -->
                                <Button Grid.Column="0"
                                        Clicked="OnToggleDoneClicked"
                                        CommandParameter="{Binding .}"
                                        FontSize="20"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        CornerRadius="22"
                                        BackgroundColor="#E3F2FD"
                                        TextColor="#1A237E"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsDone}" Value="True">
                                            <Setter Property="Text" Value="✓"/>
                                            <Setter Property="BackgroundColor" Value="#E3F2FD"/>
                                            <Setter Property="TextColor" Value="#2196F3"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsDone}" Value="False">
                                            <Setter Property="Text" Value="○"/>
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>

                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding TypeOpis}"
                                           FontSize="16"
                                           TextColor="#263238"
                                           FontAttributes="Bold">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsCancelled}" Value="True">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                <Setter Property="TextColor" Value="#B0BEC5"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Label Text="{Binding Notes}"
                                           FontSize="13"
                                           TextColor="#607D8B">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsCancelled}" Value="True">
                                                <Setter Property="TextColor" Value="#B0BEC5"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="{Binding ScheduledAtOpis}"
                                               FontSize="12"
                                               TextColor="#90A4AE"/>
                                        <Label Text="•" FontSize="12" TextColor="#CFD8DC"/>
                                        <Label Text="{Binding AnimalOpis}"
                                               FontSize="12"
                                               TextColor="#90A4AE"/>
                                        <Label Text="•" FontSize="12" TextColor="#CFD8DC"/>
                                        <Label Text="{Binding StatusOpis}"
                                               FontSize="12"
                                               TextColor="#90A4AE"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <Button Grid.Column="2"
                                        Text="ANULUJ"
                                        Clicked="OnCancelTaskClicked"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="16"
                                        HeightRequest="40"
                                        Padding="14,0"
                                        BackgroundColor="#FFF3E0"
                                        TextColor="#E65100"
                                        FontAttributes="Bold"
                                        VerticalOptions="Center"/>

                                <Button Grid.Column="3"
                                        Text="✕"
                                        Clicked="OnDeleteTaskClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="#EF5350"
                                        FontSize="20"
                                        WidthRequest="50"
                                        HeightRequest="50"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </VerticalStackLayout.BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
