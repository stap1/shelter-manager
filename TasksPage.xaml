<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ShelterManager.Models"
             x:Class="ShelterManager.TasksPage"
             Title="Zadania"
             BackgroundColor="#F4F7FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2196F3" Offset="0.0" />
                <GradientStop Color="#21CBF3" Offset="1.0" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid MaximumWidthRequest="800" HorizontalOptions="Center" RowDefinitions="Auto, Auto, *">

        <VerticalStackLayout Grid.Row="0" Margin="0,30,0,25" Spacing="8">
            <Label Text="HARMONOGRAM" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="#1A237E" 
                   HorizontalOptions="Center" 
                   CharacterSpacing="1"/>

            <Label Text="Lista zadań na dziś" 
                   FontSize="16" 
                   TextColor="#7986CB" 
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <Border Grid.Row="1" 
                Margin="20,0,20,30" 
                StrokeShape="RoundRectangle 30" 
                BackgroundColor="White" 
                StrokeThickness="0" 
                HeightRequest="60">

            <Border.Shadow>
                <Shadow Brush="#90A4AE" Offset="0,4" Opacity="0.2" Radius="10"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*, Auto" Padding="5">
                <Entry x:Name="EntryNoweZadanie" 
                       Placeholder="Wpisz nowe zadanie..." 
                       Margin="20,0" 
                       VerticalOptions="Center"
                       FontSize="16"
                       TextColor="#37474F"
                       PlaceholderColor="#B0BEC5"/>

                <Button Grid.Column="1" 
                        Text="DODAJ" 
                        Clicked="OnAddClicked" 
                        Background="{StaticResource PrimaryGradient}" 
                        TextColor="White" 
                        CornerRadius="25" 
                        HeightRequest="50" 
                        WidthRequest="100"
                        FontAttributes="Bold"
                        Shadow="{Shadow Brush=#2196F3, Offset='0,4', Opacity=0.3, Radius=8}"/>
            </Grid>
        </Border>

        <CollectionView Grid.Row="2" 
                        ItemsSource="{Binding Zadania}" 
                        Margin="20,0">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Zadanie">
                    <Border StrokeShape="RoundRectangle 20" 
                            BackgroundColor="White" 
                            StrokeThickness="0" 
                            Padding="0">

                        <Border.Shadow>
                            <Shadow Brush="#CFD8DC" Offset="0,2" Opacity="0.1" Radius="5"/>
                        </Border.Shadow>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTaskTapped"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="50, *, Auto" Padding="0,15">

                            <CheckBox Grid.Column="0" 
                                      IsChecked="{Binding CzyZrobione, Mode=TwoWay}" 
                                      Color="#2196F3" 
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"
                                      InputTransparent="True"/>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Tresc}" 
                                       FontSize="16" 
                                       TextColor="#37474F"
                                       FontAttributes="Bold">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding CzyZrobione}" Value="True">
                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            <Setter Property="TextColor" Value="#B0BEC5"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <Label Text="{Binding Godzina}" 
                                       FontSize="12" 
                                       TextColor="#90A4AE"/>
                            </VerticalStackLayout>

                            <Button Grid.Column="2" 
                                    Text="✕" 
                                    Clicked="OnDeleteTaskClicked" 
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="Transparent" 
                                    TextColor="#EF5350" 
                                    FontSize="20"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>