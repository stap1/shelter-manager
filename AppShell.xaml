<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ShelterManager.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ShelterManager"
    Title="ShelterManager"
    Shell.NavBarIsVisible="False" 
    Shell.BackgroundColor="White"
    Shell.ForegroundColor="#2196F3"
    Shell.TitleColor="#333333"
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarTitleColor="#999999"
    Shell.TabBarUnselectedColor="#999999"
    Shell.TabBarForegroundColor="#2196F3">

    <TabBar x:Name="DolnyPasek">
        <ShellContent
            Title="ZWIERZĘTA"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="KLATKI"
            ContentTemplate="{DataTemplate local:CagesPage}"
            Route="CagesPage" />

        <ShellContent
            Title="MAGAZYN"
            ContentTemplate="{DataTemplate local:InventoryPage}"
            Route="InventoryPage" />

        <ShellContent
            Title="ZADANIA"
            ContentTemplate="{DataTemplate local:TasksPage}"
            Route="TasksPage" />

        <ShellContent
            Title="ADOPCJE"
            ContentTemplate="{DataTemplate local:AdoptionApplicationsPage}"
            Route="AdoptionApplicationsPage" />

        <ShellContent
            Title="ARCHIWUM"
            ContentTemplate="{DataTemplate local:ArchivePage}"
            Route="ArchivePage" />

        <ShellContent
            Title="WYLOGUJ"
            ContentTemplate="{DataTemplate local:LoginPage}"
            Route="LogoutPage" />
    </TabBar>

</Shell>