<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShelterManager.LoginPage"
             BackgroundColor="#F2F5F8">

    <VerticalStackLayout VerticalOptions="Center" Spacing="20" Padding="30">
        <Label Text="🐶" FontSize="80" HorizontalOptions="Center"/>
        <Label Text="ShelterManager" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2196F3"/>
        <Label Text="Wybierz profil i wpisz hasło dla Admina:" HorizontalOptions="Center" TextColor="#777777"/>

        <Frame Margin="20,0,20,10" Padding="15,0" CornerRadius="15" HasShadow="False" BorderColor="#DDD">
            <Entry x:Name="PasswordEntry" 
                   Placeholder="Hasło (tylko dla Admina)" 
                   IsPassword="True" 
                   HorizontalTextAlignment="Center"/>
        </Frame>

        <Button Text="ADMINISTRATOR" 
                Clicked="OnAdminClicked"
                BackgroundColor="#2196F3" 
                TextColor="White" 
                HeightRequest="60" 
                CornerRadius="30"
                FontSize="16"
                FontAttributes="Bold"/>

        <BoxView HeightRequest="1" Color="#DDD" Margin="0,10"/>

        <Button Text="PRACOWNIK" 
                Clicked="OnUserClicked"
                BackgroundColor="White" 
                TextColor="#2196F3" 
                BorderColor="#2196F3"
                BorderWidth="2"
                HeightRequest="60" 
                CornerRadius="30"
                FontSize="16"
                FontAttributes="Bold"/>
    </VerticalStackLayout>
</ContentPage>