<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ShelterManager.Models"
             x:Class="ShelterManager.MainPage"
             Title="Schronisko"
             BackgroundColor="#F4F7FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <LinearGradientBrush x:Key="FabGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2196F3" Offset="0.0" />
                <GradientStop Color="#21CBF3" Offset="1.0" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, Auto, *">

        <BoxView Grid.Row="0" Grid.RowSpan="3" 
                 Color="#E3F2FD" 
                 Opacity="0.5"
                 VerticalOptions="Fill" 
                 HorizontalOptions="Fill"/>

        <Grid Grid.Row="0" Grid.RowSpan="4"
              RowDefinitions="Auto, Auto, Auto, *" 
              MaximumWidthRequest="1000" 
              HorizontalOptions="Center"
              Padding="20,10"
              RowSpacing="20">

            <VerticalStackLayout Grid.Row="0" Margin="0,20,0,0" Spacing="5">
                <Label Text="STAN SCHRONISKA" 
                       FontSize="32" 
                       FontAttributes="Bold" 
                       TextColor="#1A237E" 
                       HorizontalOptions="Center"
                       CharacterSpacing="1"/>
                <Label Text="Panel zarządzania i ewidencja podopiecznych" 
                       FontSize="16" 
                       TextColor="#5C6BC0" 
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Grid Grid.Row="1" ColumnDefinitions="*, *" ColumnSpacing="20">
                <Border Grid.Column="0" BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 20" StrokeThickness="0" HeightRequest="100">
                    <Border.Shadow>
                        <Shadow Brush="#90A4AE" Offset="0,4" Opacity="0.2" Radius="10"/>
                    </Border.Shadow>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="15" VerticalOptions="Center">
                        <Border StrokeShape="RoundRectangle 30" HeightRequest="50" WidthRequest="50" BackgroundColor="#E3F2FD" StrokeThickness="0">
                            <Label Text="🐾" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Wszystkie" FontSize="12" TextColor="#90A4AE" TextTransform="Uppercase" FontAttributes="Bold"/>
                            <Label x:Name="LblTotalAnimals" Text="0" FontAttributes="Bold" FontSize="24" TextColor="#263238"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Border Grid.Column="1" BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 20" StrokeThickness="0" HeightRequest="100">
                    <Border.Shadow>
                        <Shadow Brush="#90A4AE" Offset="0,4" Opacity="0.2" Radius="10"/>
                    </Border.Shadow>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="15" VerticalOptions="Center">
                        <Border StrokeShape="RoundRectangle 30" HeightRequest="50" WidthRequest="50" BackgroundColor="#FFF3E0" StrokeThickness="0">
                            <Label Text="🏥" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Kwarantanna" FontSize="12" TextColor="#90A4AE" TextTransform="Uppercase" FontAttributes="Bold"/>
                            <Label x:Name="LblInQuarantine" Text="0" FontAttributes="Bold" FontSize="24" TextColor="#E65100"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <Border Grid.Row="2" Margin="0,0,0,20" Padding="15,0" StrokeShape="RoundRectangle 30" HeightRequest="50" BackgroundColor="White" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#5C6BC0" Offset="0,4" Opacity="0.15" Radius="10"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="Auto, *">
                    <Label Text="🔍" VerticalOptions="Center" FontSize="18" Margin="0,0,10,0" Opacity="0.5"/>
                    <SearchBar x:Name="SearchBarZwierzeta" 
                               Grid.Column="1"
                               Placeholder="Wpisz imię zwierzaka..." 
                               TextChanged="OnSearchTextChanged"
                               BackgroundColor="Transparent"
                               CancelButtonColor="Gray"
                               VerticalOptions="Center"
                               FontSize="16"/>
                </Grid>
            </Border>

            <CollectionView Grid.Row="3" 
                            x:Name="ListaZwierzat" 
                            ItemsSource="{Binding FiltrowaneZwierzeta}"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged"
                            Margin="0">

                <CollectionView.EmptyView>
                    <Grid Padding="0,50,0,0">
                        <VerticalStackLayout VerticalOptions="Start" HorizontalOptions="Center" Spacing="10">
                            <Label Text="🤷‍♂️" FontSize="60" HorizontalOptions="Center" Opacity="0.8"/>
                            <Label Text="Nie znaleziono zwierzaka" FontSize="20" TextColor="#455A64" HorizontalOptions="Center" FontAttributes="Bold"/>
                            <Label Text="Spróbuj wpisać inne imię" FontSize="14" TextColor="#90A4AE" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Zwierze">
                        <Grid Padding="5">
                            <Border StrokeShape="RoundRectangle 25" StrokeThickness="0" BackgroundColor="White" HeightRequest="130">
                                <Border.Shadow>
                                    <Shadow Brush="#455A64" Offset="0,4" Opacity="0.1" Radius="15"/>
                                </Border.Shadow>
                                <Grid ColumnDefinitions="130, *, Auto">
                                    <Grid Grid.Column="0">
                                        <BoxView Color="#F5F5F5"/>
                                        <ActivityIndicator IsRunning="True" Color="#2196F3" Scale="0.5"/>
                                        <Image Source="{Binding Zdjecie}" Aspect="AspectFill" HorizontalOptions="Fill" VerticalOptions="Fill"/>
                                    </Grid>
									<VerticalStackLayout Grid.Column="1" Padding="20,15" VerticalOptions="Center" Spacing="4">
										<Label Text="{Binding Imie}" FontSize="20" FontAttributes="Bold" TextColor="#263238"/>
										<Label Text="{Binding GatunekOpis}" FontSize="14" TextColor="#78909C"/>
										<Label Text="{Binding Rasa}" FontSize="14" TextColor="#78909C"/>
										<Border HorizontalOptions="Start" Margin="0,6,0,0" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}" Padding="10,4">
											<Label Text="{Binding StatusOpis}" TextColor="White" FontSize="11" FontAttributes="Bold" TextTransform="Uppercase"/>
										</Border>
									</VerticalStackLayout>
                                    <Label Grid.Column="2" Text="&#8942;" FontSize="28" TextColor="#CFD8DC" VerticalOptions="Start" Padding="0,10,15,0"/>
                                </Grid>
                                <FlyoutBase.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Usuń zwierzaka" Clicked="OnDeleteClicked" CommandParameter="{Binding .}" />
                                    </MenuFlyout>
                                </FlyoutBase.ContextFlyout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <Button Text="+" Grid.Row="3"
                Clicked="OnAddClicked"
                FontSize="36"
                TextColor="White"
                Background="{StaticResource FabGradient}"
                CornerRadius="40"
                WidthRequest="80"
                HeightRequest="80"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="40"
                Shadow="{Shadow Brush=#2196F3, Offset='0,10', Opacity=0.4, Radius=15}"/>
    </Grid>
</ContentPage>