<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ShelterManager.Models"
             x:Class="ShelterManager.MainPage"
             Title="Schronisko"
             BackgroundColor="#F2F5F8">

    <Grid RowDefinitions="Auto, Auto, Auto, *">

        <VerticalStackLayout Grid.Row="0" Margin="0,20,0,10" Spacing="5">
            <Label Text="STAN SCHRONISKA" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#333333" 
                   HorizontalOptions="Center"
                   CharacterSpacing="2"/>
            
            <Label Text="Panel zarządzania i lista zwierząt" 
                   FontSize="14" 
                   TextColor="#999999" 
                   HorizontalOptions="Center"/>
            
            <BoxView HeightRequest="4" 
                     WidthRequest="60" 
                     Color="#4CAF50" 
                     CornerRadius="2" 
                     HorizontalOptions="Center"
                     Margin="0,5,0,0"/>
        </VerticalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="*, *" Margin="20,5" ColumnSpacing="15">
            <Frame Grid.Column="0" BackgroundColor="White" Padding="15" CornerRadius="15" HasShadow="False">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="15" VerticalOptions="Center">
                    <Label Text="🐾" FontSize="24" VerticalOptions="Center"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Zwierząt" FontSize="11" TextColor="Gray"/>
                        <Label x:Name="LblTotalAnimals" Text="0" FontAttributes="Bold" FontSize="20" TextColor="#333"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>
            
            <Frame Grid.Column="1" BackgroundColor="White" Padding="15" CornerRadius="15" HasShadow="False">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="15" VerticalOptions="Center">
                    <Label Text="🏥" FontSize="24" VerticalOptions="Center"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Kwarantanna" FontSize="11" TextColor="Gray"/>
                        <Label x:Name="LblInQuarantine" Text="0" FontAttributes="Bold" FontSize="20" TextColor="#FF9800"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>
        </Grid>

        <Frame Grid.Row="2" Margin="20,10" Padding="10,0" CornerRadius="25" HeightRequest="50" HasShadow="False" BorderColor="#DDD" BackgroundColor="White">
            <SearchBar x:Name="SearchBarZwierzeta" 
                       Placeholder="Szukaj po imieniu..." 
                       TextChanged="OnSearchTextChanged"
                       BackgroundColor="Transparent"
                       CancelButtonColor="Gray"
                       VerticalOptions="Center"/>
        </Frame>

        <Grid Grid.Row="3">
            <CollectionView x:Name="ListaZwierzat" 
                            ItemsSource="{Binding FiltrowaneZwierzeta}"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged"
                            Margin="15">
                
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Zwierze">
                        
                        <Frame HasShadow="True" 
                               Padding="0" 
                               CornerRadius="20" 
                               IsClippedToBounds="True"
                               BackgroundColor="White"
                               BorderColor="Transparent"
                               HeightRequest="120">
                            
                            <Grid ColumnDefinitions="120, *">
                                <Image Grid.Column="0"
                                       Source="{Binding Zdjecie}" 
                                       Aspect="AspectFill" 
                                       HeightRequest="120" 
                                       WidthRequest="120"/>

                                <StackLayout Grid.Column="1" 
                                             Padding="15,10" 
                                             VerticalOptions="Center" 
                                             Spacing="5">
                                    
                                    <Label Text="{Binding Imie}" 
                                           FontSize="20" 
                                           FontAttributes="Bold" 
                                           TextColor="#333333" />
                                    
                                    <Label Text="{Binding Rasa}" 
                                           FontSize="14" 
                                           TextColor="#777777" />
                                    
                                    <Frame Padding="10,4" 
                                           CornerRadius="8" 
                                           BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                           HorizontalOptions="Start"
                                           BorderColor="Transparent"
                                           Margin="0,5,0,0">
                                        <Label Text="{Binding Status}" 
                                               FontSize="11" 
                                               FontAttributes="Bold" 
                                               TextColor="White" />
                                    </Frame>
                                </StackLayout>

                                <FlyoutBase.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Usuń zwierzaka" 
                                                        Clicked="OnDeleteClicked" 
                                                        CommandParameter="{Binding .}" />
                                    </MenuFlyout>
                                </FlyoutBase.ContextFlyout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="+" 
                    Clicked="OnAddClicked"
                    FontSize="32"
                    TextColor="White"
                    BackgroundColor="#2196F3"
                    CornerRadius="35"
                    WidthRequest="70"
                    HeightRequest="70"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="25"
                    Shadow="{Shadow Brush=Black, Offset='2,2', Opacity=0.3, Radius=5}"/>
        </Grid>
    </Grid>
</ContentPage>